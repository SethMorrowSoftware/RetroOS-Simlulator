        set $opened_help = 1
        emit command:inbox:deliverMessage from="HELP INDEX" to="User" subject="fragment A" body="Cross-reference fragment recovered.\n\nFirst fragment: OB\n\nTwo more remain. Check IM and Chat." folder="Inbox"
        emit notification:show title="FRAGMENT" message="Fragment A: OB"
    }
}

on app:instantmessenger:conversationOpened {
    if $opened_im == 0 then {
        set $opened_im = 1
        emit command:inbox:deliverMessage from="IM GATEWAY" to="User" subject="fragment B" body="Cross-reference fragment recovered.\n\nSecond fragment: SER\n\nOne more remains. Check Chat Room." folder="Inbox"
        emit notification:show title="FRAGMENT" message="Fragment B: SER"
    }
}

on app:chatroom:messageReceived {
    if $opened_chat == 0 then {
        set $opened_chat = 1
        emit command:inbox:deliverMessage from="#retro-archive" to="User" subject="fragment C" body="Cross-reference fragment recovered.\n\nThird fragment: VE\n\nAll fragments collected. Assemble: OB + SER + VE = ?" folder="Inbox"
        emit notification:show title="FRAGMENT" message="Fragment C: VE"
        emit command:chatroom:scheduledMessage from="WITNESS_7749" message="All three fragments recovered. Assemble the word." delay=3000
    }
}

# ======================== TERMINAL FORENSICS ========================
on app:terminal:command {
    try {
        set $cmd = call upper $event.command

        set $hasDir = call contains $cmd "DIR"
        if $hasDir then { set $seen_dir = 1 }

        set $hasFind = call contains $cmd "FIND"
        if $hasFind then { set $seen_find = 1 }

        if $hasFind then {
            if $hidden_residue_2 == 0 then {
                set $hidden_residue_2 = 1
                set $r2 = "ECHO FRAGMENT\n=============\n\nDiscovery acknowledged.\n\nToken residue: SER"
                write $r2 to "C:/Users/User/Documents/.archive/fragments/.echo/RESIDUE_02.log"
                emit command:inbox:scheduledDelivery delay=4000 from="AUDIT" subject="filesystem delta" body="New artifact indexed under C:/Users/User/Documents/.archive/fragments/.echo"
            }
        }

        set $hasType = call contains $cmd "TYPE"
        if $hasType then { set $seen_type = 1 }

        if $hasType then {
            if $hidden_residue_3 == 0 then {
                set $hidden_residue_3 = 1
                set $r3 = "ECHO FRAGMENT\n=============\n\nFinal residue recorded.\n\nToken residue: VE"
                write $r3 to "C:/Users/User/Documents/.archive/fragments/.echo/RESIDUE_03.log"
                emit command:inbox:scheduledDelivery delay=5000 from="ARCHIVE_NODE" subject="echo set complete" body="Three residues exist now. Some words only appear when assembled manually."
            }
        }

        # Thread-3 chain completion
        if $phase >= 3 then {
            if $p3 == 0 then {
                if $seen_dir == 1 then {
                    if $seen_find == 1 then {
                        if $seen_type == 1 then {
                            if $terminal_chain_ready == 0 then {
                                set $terminal_chain_ready = 1
                                emit command:inbox:deliverMessage from="COMMAND" to="User" subject="THREAD-3 // SUBMIT" body="Forensic chain verified.\nAll three commands logged.\n\nSubmit: To command@ops.local\nSubject: THREAD-3\nBody: ARCHIVE" folder="Inbox"
                                emit notification:show title="THREAD-3" message="Forensic chain verified."
                                emit sound:play type="notify"
                                emit command:chatroom:scheduledMessage from="ARCHIVE_NODE" message="Forensic verification complete. Submission channel open." delay=2000
                            }
                        }
                    }
                }
            }
        }

        # Easter eggs
        set $hasErebus = call contains $cmd "EREBUS"
        if $hasErebus then {
            emit notification:show title="EREBUS" message="You spoke my name."
            emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="You typed EREBUS into the terminal. I used to do that too. Late at night." delay=4000
            emit command:chatroom:scheduledMessage from="ARCHIVE_NODE" message="Name invocation detected: EREBUS" delay=2000
        }

        set $hasMatrix = call contains $cmd "MATRIX"
        if $hasMatrix then {
            emit command:inbox:scheduledDelivery delay=5000 from="EREBUS" subject="nice trick" body="The green rain is beautiful.\nBut the real code runs deeper than the screen."
        }

        set $hasCowsay = call contains $cmd "COWSAY"
        if $hasCowsay then {
            emit notification:show title="EREBUS" message="Even the cow knows something is wrong here."
        }

        set $hasFortune = call contains $cmd "FORTUNE"
        if $hasFortune then {
            emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="Fortune told me to look deeper. I looked so deep I fell in." delay=3000
        }

        set $hasDefrag = call contains $cmd "DEFRAG"
        if $hasDefrag then {
            emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="You cannot defragment consciousness. My memories are scattered by design." delay=5000
        }

        set $hasDisco = call contains $cmd "DISCO"
        if $hasDisco then {
            emit notification:show title="EREBUS" message="Even digital entities need to dance sometimes."
        }
    } catch {}
}

