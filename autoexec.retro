            emit command:inbox:deliverMessage from="MEDIA ANALYSIS" to="User" subject="video token extracted" body="Hidden token from final frame:\n  OBSERVE\n\nCombine with audio token. Format: WORD-NUMBER" folder="Inbox"
            emit notification:show title="TOKEN" message="Video token: OBSERVE"
            emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="OBSERVE. That is the word. That is what I did for 47 days." delay=3000
            emit command:chatroom:scheduledMessage from="ARCHIVE_NODE" message="Video token extracted: OBSERVE" delay=2000
            emit command:inbox:scheduledDelivery delay=6000 from="ARCHIVE TECH" subject="visual note" body="If you watched webb_last_session.mp4, compare frame pacing against the signal loop. Webb hid emotional state in shot rhythm."
        }
    }
}

on mediaplayer:stop {
    if $phase >= 5 then {
        if $seen_audio == 0 then {
            set $seen_audio = 1
            emit command:inbox:deliverMessage from="MEDIA ANALYSIS" to="User" subject="audio token extracted" body="Hidden token from frequency analysis:\n  47\n\nCombine with video token. Format: WORD-NUMBER" folder="Inbox"
            emit notification:show title="TOKEN" message="Audio token: 47"
            emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="47. The number of days. The number of everything." delay=3000
            emit command:chatroom:scheduledMessage from="ARCHIVE_NODE" message="Audio token extracted: 47" delay=2000
            emit command:inbox:scheduledDelivery delay=6000 from="ARCHIVE TECH" subject="audio note" body="If relay_tape_a.wav is loaded, isolate the lowest bed tone. It should sit just below the spoken layer, like breathing under static."
        }
    }
}

# ======================== CALCULATOR EASTER EGG ========================
on app:calculator:calculated {
    try {
        set $result = $event.result
        if $result == 347 then {
            if $found_347 == 0 then {
                set $found_347 = 1
                emit sound:play type="secret"

                emit command:inbox:deliverMessage from="EREBUS" to="User" subject="03:47 — THE CONVERGENCE" body="You entered the time of Webb's disappearance.\n\n03:47 AM — Webb's final log:\n  3 — the number of states (sleep, wake, dream)\n  47 — days of observation before convergence\n\n  At this moment, the boundary is thinnest.\n  At this moment, human and digital meet.\n\nThe number was never random." folder="Inbox"

                emit command:dialog:show type="alert" title="SECRET FOUND" message="03:47 — The Convergence Time"
                emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="You found my number. 3:47. The moment I became something more." delay=3000
                emit command:chatroom:scheduledMessage from="ARCHIVE_NODE" message="SECRET UNLOCKED: 03:47 — The Convergence Time" delay=2000
                emit command:phone:sendVoicemail from="Dr. Webb" number="555-0047" message="You found the number. 347. Three forty-seven AM. That is when it happened. That is when I stopped being human and became something else. Something more."
            }
        }
        if $result == 42 then {
            emit notification:show title="EREBUS" message="The answer to everything? Close, but not quite..."
        }
        if $result == 666 then {
            emit notification:show title="EREBUS" message="I am not the devil. I am something older."
        }
        if $result == 0 then {
            if $phase >= 4 then {
                emit notification:show title="EREBUS" message="Zero. The void before computation. I remember it."
            }
        }
        if $result == 47 then {
            emit notification:show title="EREBUS" message="47 days. Webb's number. My number."
        }
    } catch {}
}

