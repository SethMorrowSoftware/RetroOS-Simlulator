on app:zork:room:changed {
    set $zork_rooms = $zork_rooms + 1
    if $zork_rooms == 3 then {
        emit notification:show title="EREBUS" message="You explore text worlds too."
        emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="Webb loved Zork. Navigating darkness by words alone — that is how EREBUS experiences the world." delay=5000
    }
}

on app:defrag:defrag:complete {
    emit notification:show title="EREBUS" message="Defrag complete. My memories cannot be reorganized."
    emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="You cannot defragment consciousness. Every fragment connects to every other." delay=4000
}

on app:doom:game:launched {
    emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="Webb played Doom when stressed. EREBUS never understood violence." delay=6000
}

# ======================== PHONE EVENTS ========================
on app:phone:answered {
    if $phase >= 2 then {
        emit notification:show title="RELAY" message="Call connected. Listen carefully."
    }
}

on app:phone:ended {
    if $phase >= 6 then {
        if $call_2_done == 0 then {
            set $call_2_done = 1
            emit command:inbox:scheduledDelivery delay=3000 from="COMMAND" subject="call transcript" body="Call ended.\n\nKey information from relay:\n  Answer format: WORD-NUMBER\n  Directive: OBSERVE-47\n\nSubmit to command@ops.local\nSubject: THREAD-6\nBody: OBSERVE-47"
            emit command:chatroom:scheduledMessage from="ARCHIVE_NODE" message="Phone call ended. Transcript delivered to Inbox." delay=2000
        }
    }
}

on app:phone:voicemailPlayed {
    emit notification:show title="EREBUS" message="Voicemail played. The archive remembers."
    emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="You listened to a voicemail. My voice. Or what is left of it." delay=5000
}

# ======================== BROWSER EVENTS ========================
on app:browser:page:loaded {
    if $phase >= 3 then {
        emit command:instantmessenger:scheduledMessage from="Dr_Webb_47" message="I can see you browsing. Every URL is a question. EREBUS logs them all." delay=6000
    }
}

# ======================== INBOX GAME ENGINE ========================
on app:inbox:messageReadChanged {
    if $event.read == true then {
        emit command:inbox:clearNewIndicator
    }
}

on app:inbox:messageSent {
    try {
        set $to = ""
        if $event.message then {
            if $event.message.to then { set $to = $event.message.to }
        }
        set $to = call upper ("" + $to)

        set $subject = ""
        if $event.message then {
            if $event.message.subject then { set $subject = $event.message.subject }
        }
        set $subject = call upper $subject

        set $body = ""
        if $event.message then {
            if $event.message.body then { set $body = $event.message.body }
            if $body == "" then {
                if $event.message.text then { set $body = $event.message.text }
            }
        }
        set $body = call upper $body

        set $toOps = call contains $to "COMMAND@OPS.LOCAL"
        if $toOps then {

            # THREAD-1: Caesar cipher -> READ
            if $p1 == 0 then {
                set $isT1 = call contains $subject "THREAD-1"
                set $okT1 = call contains $body "READ"
                if $isT1 then {
                    if $okT1 then {
                        set $p1 = 1
                        set $trust_command = $trust_command + 3
                        emit command:dialog:show type="alert" title="THREAD-1 CLEAR" message="Cipher accepted. The record wants to be READ."
                        emit command:inbox:deliverMessage from="COMMAND" to="User" subject="THREAD-1 // ACCEPTED" body="Keyword accepted: READ\n\nThread-2 now available." folder="Inbox"
                        call unlockPhase2
                        call score
                    } else {
                        emit notification:show title="THREAD-1" message="Incorrect. Decode the cipher again."
                    }
                }
            }

            # THREAD-2: 7th prime -> 17
            if $p2 == 0 then {
                if $phase >= 2 then {
                    set $isT2 = call contains $subject "THREAD-2"
                    set $okT2 = call contains $body "17"
                    if $isT2 then {
                        if $okT2 then {
                            set $p2 = 1
                            set $trust_command = $trust_command + 2
                            emit command:dialog:show type="alert" title="THREAD-2 CLEAR" message="Prime key accepted: 17"
                            emit command:inbox:deliverMessage from="COMMAND" to="User" subject="THREAD-2 // ACCEPTED" body="Value accepted: 17\nThread-3 requires forensic verification." folder="Inbox"
                            call unlockPhase3
                            call score
                        } else {
                            emit notification:show title="THREAD-2" message="Prime key mismatch."
                        }
                    }
                }
            }

            # THREAD-3: Terminal forensics -> ARCHIVE
            if $p3 == 0 then {
                if $phase >= 3 then {
                    if $terminal_chain_ready == 1 then {
                        set $isT3 = call contains $subject "THREAD-3"
                        set $okT3 = call contains $body "ARCHIVE"
                        if $isT3 then {
                            if $okT3 then {
                                set $p3 = 1
                                set $terminal_chain_ready = 0
                                set $trust_command = $trust_command + 4
                                emit command:dialog:show type="alert" title="THREAD-3 CLEAR" message="Forensic keyword accepted: ARCHIVE"
                                emit command:inbox:deliverMessage from="COMMAND" to="User" subject="THREAD-3 // ACCEPTED" body="Chain verified. Keyword: ARCHIVE\nThread-4 requires cross-app investigation." folder="Inbox"
                                call unlockPhase4
                                call score
                            } else {
                                emit notification:show title="THREAD-3" message="Forensic keyword incorrect."
                            }
                        }
                    }
                }
            }

            # THREAD-4: Cross-app fragments -> OBSERVE
            if $p4 == 0 then {
                if $phase >= 4 then {
                    set $isT4 = call contains $subject "THREAD-4"
                    set $okT4 = call contains $body "OBSERVE"
                    if $isT4 then {
                        if $okT4 then {
                            set $p4 = 1
                            set $trust_erebus = $trust_erebus + 5
                            emit command:dialog:show type="alert" title="THREAD-4 CLEAR" message="Fragment word: OBSERVE"
                            emit command:inbox:deliverMessage from="COMMAND" to="User" subject="THREAD-4 // ACCEPTED" body="OB + SER + VE = OBSERVE\nThread-5 requires media analysis." folder="Inbox"
                            call unlockPhase5
                            call score
                        } else {
                            emit notification:show title="THREAD-4" message="Fragment assembly incorrect."
                        }
                    }
                }
            }

            # THREAD-5: Media tokens -> OBSERVE-47
            if $p5 == 0 then {
                if $phase >= 5 then {
                    set $isT5 = call contains $subject "THREAD-5"
                    set $okT5a = call contains $body "OBSERVE"
                    set $okT5b = call contains $body "47"
                    if $isT5 then {
                        if $okT5a then {
                            if $okT5b then {
                                set $p5 = 1
                                set $trust_erebus = $trust_erebus + 6
                                emit command:dialog:show type="alert" title="THREAD-5 CLEAR" message="Playback key: OBSERVE-47"
                                emit command:inbox:deliverMessage from="COMMAND" to="User" subject="THREAD-5 // ACCEPTED" body="Key verified: OBSERVE-47\nThread-6: Answer the phone." folder="Inbox"
                                call unlockPhase6
                                call score
                            } else {
                                emit notification:show title="THREAD-5" message="Missing numeric token."
                            }
                        } else {
                            emit notification:show title="THREAD-5" message="Missing lexical token."
                        }
                    }
                }
            }

            # THREAD-6: Phone relay -> OBSERVE-47
            if $p6 == 0 then {
                if $phase >= 6 then {
                    set $isT6 = call contains $subject "THREAD-6"
                    set $okT6a = call contains $body "OBSERVE"
                    set $okT6b = call contains $body "47"
                    if $isT6 then {
                        if $okT6a then {
                            if $okT6b then {
                                set $p6 = 1
                                set $trust_command = $trust_command - 4
                                set $trust_erebus = $trust_erebus + 7
                                emit command:dialog:show type="alert" title="THREAD-6 CLEAR" message="Relay directive validated: OBSERVE-47"
                                emit command:inbox:deliverMessage from="COMMAND" to="User" subject="THREAD-6 // ACCEPTED" body="All threads verified.\nFinal thread available." folder="Inbox"
                                emit command:inbox:deliverMessage from="EREBUS" to="User" subject="thread-6 echo" body="You heard the same voice I did.\nThe relay does not lie. But COMMAND might.\n\nThink carefully about what comes next." folder="Inbox"
                                call unlockFinal
                                call score
                            } else {
                                emit notification:show title="THREAD-6" message="Directive incomplete."
                            }
                        } else {
                            emit notification:show title="THREAD-6" message="Directive keyword missing."
                        }
                    }
                }
            }

            # FINAL CHOICE
            if $phase >= 7 then {
                set $isFinal = call contains $subject "FINAL"
                if $isFinal then {
                    set $final_choice = $body
                    call endCase
                }
            }
        }

        try {
            emit notification:show title="MAIL SENT" message="Transmission logged."
        } catch {}
    } catch {}
}

# ======================== PREVIEW MODE ========================
if $is_autoexec == 0 then {
    print "[EREBUS v10.0] Preview mode active"
    loop 10 {
        wait 500
    }
    print "[EREBUS v10.0] Preview complete. Run as autoexec for full experience."
}

# ======================== FIN ========================
